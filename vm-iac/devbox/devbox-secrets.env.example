# Template for evilbot:/root/.secrets/devbox.env
# Copy this file to that path on evilbot and fill in real values.
# This file is NEVER committed — it lives only on evilbot.
#
# Usage:
#   scp devbox-secrets.env.example root@192.168.1.145:/root/.secrets/devbox.env
#   ssh root@192.168.1.145 "vi /root/.secrets/devbox.env"
#
# Note: Claude Code authenticates via OAuth (claude login) on first SSH.
# No API key needed here — the login flow handles it.

# Git identity written to ~/.gitconfig in the container
GITHUB_USER="Your Name"
GITHUB_EMAIL=you@company.com

# Work GitHub SSH private key — base64-encoded so it fits in one line.
# Generate or encode an existing key:
#   ssh-keygen -t ed25519 -f ~/.ssh/work_devbox_id_ed25519 -C "devbox@work"
#   base64 < ~/.ssh/work_devbox_id_ed25519   # paste output below
#   cat ~/.ssh/work_devbox_id_ed25519.pub    # add this to GitHub → Settings → SSH Keys
GITHUB_SSH_KEY_B64=<base64-encoded-private-key>

# evilbot's SSH public key — allows direct ssh root@<devbox-ip> from evilbot
# Get it with: ssh root@192.168.1.145 "cat ~/.ssh/id_ed25519.pub || cat ~/.ssh/id_rsa.pub"
EVILBOT_SSH_PUBKEY="ssh-rsa AAAA... root@evilbot"
