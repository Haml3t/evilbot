# /root/.secrets/offsite-sync.env — off-host rsync target for host-offsite-sync.sh
# Copy to /root/.secrets/offsite-sync.env on evilbot and fill in real values (chmod 600).
# This file must NOT be committed to git (the .secrets dir is gitignored).

OFFSITE_HOST=192.168.0.xx        # LAN IP of the separate desktop/machine
OFFSITE_USER=youruser            # SSH user on that machine
OFFSITE_BASE=/backups/evilbot    # destination dir on that machine
