# /root/.secrets/restic-b2.env — Backblaze B2 + restic credentials
# Copy this file to /root/.secrets/restic-b2.env on evilbot and fill in real values.
# chmod 600 /root/.secrets/restic-b2.env
# This file must NOT be committed to git.

# Backblaze B2 Application Key (created at backblaze.com → App Keys)
B2_ACCOUNT_ID=your-application-key-id-here
B2_ACCOUNT_KEY=your-application-key-secret-here

# Bucket name (create at backblaze.com → Buckets → Create a Bucket)
B2_BUCKET=your-bucket-name-here

# Path within the bucket (no leading slash)
B2_PATH=evilbot

# Restic encryption passphrase — keep a copy somewhere safe (password manager)
# If lost, backups cannot be decrypted. There is no recovery.
RESTIC_PASSWORD=choose-a-strong-passphrase-here
