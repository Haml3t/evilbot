# Ignore .env file in telegram-bot
telegram-bot/.env

# Ignore top-level .env files
/.env

# Ignore all virtual environments named .venv at any level
**/.venv/

# Optional: Ignore other virtual environments by common names
venv/
**/venv/
env/
**/env/

# Terraform — use ** to catch nested paths (the old relative pattern caused the tfvars leak)
**/terraform.tfvars
**/.terraform/
**/.terraform.lock.hcl
**/terraform.tfstate
**/terraform.tfstate.backup

# Secrets & credentials
**/.env
**/secrets.yml
**/vault.yml
**/.secrets/

# Ansible backups/artifacts
ansible/backups/

# Editor/OS noise
.DS_Store
*.swp
