# Ignore .env file in telegram-bot
telegram-bot/.env

# Ignore top-level .env files
/.env

# Ignore all virtual environments named .venv at any level
**/.venv/

# Optional: Ignore other virtual environments by common names
venv/
**/venv/
env/
**/env/

# Terraform — match ALL tfvars/tfstate variants by extension, not just the
# canonical filenames. The old exact-name patterns (terraform.tfvars /
# terraform.tfstate) missed jellyfin.tfvars and terraform-301.tfstate, both of
# which hold live secrets (API token, passwords). Keep *.example committed.
**/*.tfvars
!**/*.tfvars.example
**/.terraform/
**/.terraform.lock.hcl
**/*.tfstate
**/*.tfstate.*
!**/*.tfstate.example

# Devbox secrets and private work context (leaks employer repo names + internal
# architecture). Real files stay local; only the *.example templates are public.
**/devbox-secrets.env
**/devbox/repos.txt
**/devbox/CLAUDE.md.template

# Secrets & credentials
**/.env
**/secrets.yml
**/vault.yml
**/.secrets/

# Ansible backups/artifacts
ansible/backups/

# Local security denylist consumed by the publishing-checklist scan commands.
# Holds the real sensitive terms (employer name, personal names, tailnet name,
# etc.) so they are NEVER committed. Only the *.example template is public.
.safety-denylist
!.safety-denylist.example

# Editor/OS noise
.DS_Store
*.swp
