# Copy to /opt/evilbot/.env on the evilbot-telegram VM — never commit the real .env

TELEGRAM_BOT_TOKEN=<token-from-botfather>

# Both point to the inference proxy on inferbot.
# LLM_URL defaults to IMAGEGEN_URL if not set separately.
IMAGEGEN_URL=http://192.168.0.223:8000
LLM_URL=http://192.168.0.223:8000
